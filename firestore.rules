rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isCaregiver(babyId) {
      let baby = get(/databases/$(database)/documents/babies/$(babyId)).data;
      return isAuth() && (
        request.auth.uid == baby.createdBy || 
        (request.auth.uid in baby.caregiverIds)
      );
    }

    function hasFullAccess(babyId) {
      let baby = get(/databases/$(database)/documents/babies/$(babyId)).data;
      // Safety: createdBy always has full access, otherwise check the caregivers array logic
      return isAuth() && (
        request.auth.uid == baby.createdBy ||
        (request.auth.uid in baby.caregiverIds)
      );
    }

    // Users
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // Babies
    match /babies/{babyId} {
      allow read: if isAuth(); // Allow reading metadata for invite check
      allow create: if isAuth();
      allow update: if isAuth(); // Crucial for adding oneself as caregiver via invite
      allow delete: if hasFullAccess(babyId);

      match /{allSubcollections=**} {
        allow read, write: if isCaregiver(babyId);
      }
    }

    // Invite codes
    match /inviteCodes/{code} {
      allow read, create, delete: if isAuth();
    }
  }
}
